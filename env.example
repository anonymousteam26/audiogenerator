# Claude API key - used to write the podcast script from the uploaded document
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key - used for text-to-speech narration
# Get one at https://platform.openai.com/
OPENAI_API_KEY=

# SQLite by default - zero setup, good for local dev / small deployments.
# For production on serverless (Vercel), switch prisma/schema.prisma's
# datasource to postgresql and point this at Supabase/Neon/etc instead.
DATABASE_URL="file:./dev.db"
